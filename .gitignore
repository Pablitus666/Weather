# ============================================================
# WeatherReport - Professional .gitignore (Windows / Python)
# Walter Pablo Tellez Ayala
# ============================================================

# ------------------------------------------------------------
# PYTHON
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ------------------------------------------------------------
# BUILD / DISTRIBUTION
# ------------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# Ejecutables y binarios generados
*.exe
*.msi
*.msm
*.msp
*.dll
*.pyd

# ------------------------------------------------------------
# PYINSTALLER
# ------------------------------------------------------------
# Versionar el .spec para builds reproducibles
# (NO ignorar *.spec)

# ------------------------------------------------------------
# VIRTUAL ENVIRONMENTS
# ------------------------------------------------------------
venv/
.venv/
env/
ENV/

# ------------------------------------------------------------
# ENV / SECRET CONFIGURATION
# ------------------------------------------------------------
.env
.env.*
!.env.example
secrets.json

# ------------------------------------------------------------
# CODE SIGNING (CRÍTICO)
# ------------------------------------------------------------
# Claves privadas - NUNCA subir
*.pfx
*.p12
*.pem
*.key

# Certificados públicos pueden subirse si deseas validación
# *.cer

# ------------------------------------------------------------
# LOGS
# ------------------------------------------------------------
logs/
*.log

# ------------------------------------------------------------
# TESTING / COVERAGE
# ------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
.hypothesis/

# ------------------------------------------------------------
# IDE / EDITORS
# ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# ------------------------------------------------------------
# OS FILES
# ------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# ------------------------------------------------------------
# CACHE / MISC
# ------------------------------------------------------------
.cache/
.python-version